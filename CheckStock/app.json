{
  "expo": {
    "name": "CheckStock",
    "slug": "checkstock",
    "version": "1.0.2",
    "orientation": "portrait",
    "scheme": "checkstock",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0D1B2A",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0D1B2A"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.checkstockunion.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.checkstock.app",
      "adaptiveIcon": {
        "backgroundColor": "#0D1B2A"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#0D1B2A"
        }
      ]
    ],
    "notification": {
      "iosDisplayInForeground": true
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "eea00992-3366-4d90-b37d-7dcc72083afb"
      }
    }
  }
}
